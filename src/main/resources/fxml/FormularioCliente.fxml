<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="uniquindio.edu.co.plataformaproptech.ui.FormularioClienteController"
            style="-fx-background-color: #F0F2F5;">

    <top>
        <VBox style="-fx-background-color: #1B2A3B; -fx-padding: 20 30 20 30;">
            <Label fx:id="lblTitulo" text="Nuevo Cliente"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Completa los datos del cliente"
                   style="-fx-font-size: 12px; -fx-text-fill: #7F8C9A;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="16" style="-fx-padding: 30;">

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="ID / Identificación *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtId" promptText="Ej: 1234567890"
                                   style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nombre completo *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtNombre" promptText="Ej: Juan Pérez"
                                   style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Correo *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtCorreo" promptText="Ej: juan@correo.com"
                                   style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Teléfono *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtTelefono" promptText="Ej: 3001234567"
                                   style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Tipo de cliente *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <ComboBox fx:id="cmbTipoCliente" prefWidth="999"
                                  style="-fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Estado de búsqueda *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <ComboBox fx:id="cmbEstadoBusqueda" prefWidth="999"
                                  style="-fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Tipo de inmueble deseado *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <ComboBox fx:id="cmbTipoInmueble" prefWidth="999"
                                  style="-fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Habitaciones mínimas"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtHabitaciones" promptText="Ej: 2"
                                   style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Presupuesto *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                    <TextField fx:id="txtPresupuesto" promptText="Ej: 300000000"
                               style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Zonas de interés"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                    <TextField fx:id="txtZonas" promptText="Ej: El Bosque, Centro, Laureles"
                               style="-fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 13px;"/>
                    <Label text="Separa las zonas con comas"
                           style="-fx-font-size: 11px; -fx-text-fill: #BDC8D1;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER_RIGHT"
              style="-fx-background-color: white; -fx-padding: 16 30 16 30;
                     -fx-border-color: #E0E4E8; -fx-border-width: 1 0 0 0;">
            <Button text="Cancelar" onAction="#cancelar"
                    style="-fx-background-color: transparent; -fx-text-fill: #7F8C9A;
                           -fx-font-size: 13px; -fx-cursor: hand;
                           -fx-border-color: #BDC8D1; -fx-border-radius: 8;
                           -fx-padding: 10 20 10 20;"/>
            <Button text="Guardar" onAction="#guardar"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-padding: 10 28 10 28;
                           -fx-cursor: hand;"/>
        </HBox>
    </bottom>
</BorderPane>