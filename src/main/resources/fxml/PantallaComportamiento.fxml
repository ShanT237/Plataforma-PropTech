<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="uniquindio.edu.co.plataformaproptech.ui.PantallaComportamientoController"
            style="-fx-background-color: #F0F2F5;">

    <top>
        <VBox style="-fx-background-color: #1B2A3B; -fx-padding: 20 30 20 30;">
            <Label text="Detección de Comportamiento Inusual"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Monitorea patrones atípicos en la operación de la inmobiliaria"
                   style="-fx-font-size: 12px; -fx-text-fill: #7F8C9A;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 30;">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="← Inicio" onAction="#volverAlInicio"
                        style="-fx-background-color: transparent; -fx-text-fill: #7F8C9A;
                               -fx-font-size: 13px; -fx-cursor: hand;
                               -fx-border-color: #BDC8D1; -fx-border-radius: 8;
                               -fx-padding: 10 16 10 16;"/>
                <Button text="Ejecutar todas las detecciones" onAction="#ejecutarTodas"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 20 10 20;
                               -fx-cursor: hand;"/>
            </HBox>

            <!-- Botones de detección individual -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 20;
                         -fx-background-radius: 10;">
                <Label text="Detecciones individuales:"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #7F8C9A;"/>
                <Button text="Visitas sin cierre" onAction="#detectarVisitasSinCierre"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-background-radius: 6;
                               -fx-padding: 8 14 8 14; -fx-cursor: hand;"/>
                <Button text="Clientes con múltiples visitas" onAction="#detectarClientesMultiples"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-background-radius: 6;
                               -fx-padding: 8 14 8 14; -fx-cursor: hand;"/>
                <Button text="Asesores con sobrecarga" onAction="#detectarSobrecarga"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-background-radius: 6;
                               -fx-padding: 8 14 8 14; -fx-cursor: hand;"/>
                <Button text="Concentración por zona" onAction="#detectarConcentracion"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-background-radius: 6;
                               -fx-padding: 8 14 8 14; -fx-cursor: hand;"/>
            </HBox>

            <!-- Tabla de resultados -->
            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Alertas de comportamiento inusual"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTotal" text="0 alertas detectadas"
                           style="-fx-font-size: 12px; -fx-text-fill: #7F8C9A;"/>
                </HBox>

                <TableView fx:id="tablaAlertas" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="100"/>
                        <TableColumn fx:id="colMensaje" text="Mensaje" prefWidth="300"/>
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="110"/>
                        <TableColumn fx:id="colNivel" text="Nivel" prefWidth="90"/>
                        <TableColumn fx:id="colEntidad" text="Entidad" prefWidth="150"/>
                        <TableColumn fx:id="colRevisada" text="Revisada" prefWidth="90"/>
                    </columns>
                    <placeholder>
                        <Label text="Ejecuta una detección para ver los resultados"
                               style="-fx-text-fill: #BDC8D1; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: white; -fx-padding: 12 30 12 30;
                     -fx-border-color: #E0E4E8; -fx-border-width: 1 0 0 0;">
            <Label fx:id="lblEstado" text="Listo para ejecutar detecciones"
                   style="-fx-font-size: 12px; -fx-text-fill: #7F8C9A;"/>
        </HBox>
    </bottom>
</BorderPane>