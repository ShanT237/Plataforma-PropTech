<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="uniquindio.edu.co.plataformaproptech.ui.FormularioInmuebleController"
            prefWidth="1024" prefHeight="800"
            style="-fx-background-color: #F0F2F5;">

    <!-- Encabezado -->
    <top>
        <VBox style="-fx-background-color: #1B2A3B; -fx-padding: 20 30 20 30;">
            <Label fx:id="lblTitulo" text="Nuevo Inmueble"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Completa los datos del inmueble"
                   style="-fx-font-size: 12px; -fx-text-fill: #7F8C9A;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="16" style="-fx-padding: 30;">

                <!-- Fila 1 -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Código *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtCodigo" promptText="Ej: INM-001"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Tipo *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <ComboBox fx:id="cmbTipo" prefWidth="999"
                                  style="-fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Fila 2 -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Finalidad *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <ComboBox fx:id="cmbFinalidad" prefWidth="999"
                                  style="-fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Estado *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <ComboBox fx:id="cmbEstado" prefWidth="999"
                                  style="-fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Fila 3 -->
                <VBox spacing="6">
                    <Label text="Dirección *"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                    <TextField fx:id="txtDireccion" promptText="Ej: Calle 10 # 5-23"
                               style="-fx-background-radius: 8; -fx-padding: 10;
                                      -fx-font-size: 13px;"/>
                </VBox>

                <!-- Fila 4 -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Ciudad *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtCiudad" promptText="Ej: Armenia"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Barrio / Zona"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtBarrio" promptText="Ej: El Bosque"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Fila 5 -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Precio *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtPrecio" promptText="Ej: 250000000"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Área (m²) *"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtArea" promptText="Ej: 85"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Fila 6 -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Habitaciones"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtHabitaciones" promptText="Ej: 3"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Baños"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtBanos" promptText="Ej: 2"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Código Asesor"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B2A3B;"/>
                        <TextField fx:id="txtCodigoAsesor" promptText="Ej: AS-001"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Disponible -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <CheckBox fx:id="chkDisponible" selected="true"/>
                    <Label text="Inmueble disponible"
                           style="-fx-font-size: 13px; -fx-text-fill: #1B2A3B;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Botones -->
    <bottom>
        <HBox spacing="12" alignment="CENTER_RIGHT"
              style="-fx-background-color: white; -fx-padding: 16 30 16 30;
                     -fx-border-color: #E0E4E8; -fx-border-width: 1 0 0 0;">
            <Button text="Cancelar" onAction="#cancelar"
                    style="-fx-background-color: transparent; -fx-text-fill: #7F8C9A;
                           -fx-font-size: 13px; -fx-cursor: hand;
                           -fx-border-color: #BDC8D1; -fx-border-radius: 8;
                           -fx-padding: 10 20 10 20;"/>
            <Button text="Guardar" onAction="#guardar"
                    style="-fx-background-color: #1abc9c; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-padding: 10 28 10 28;
                           -fx-cursor: hand;"/>
        </HBox>
    </bottom>
</BorderPane>